# ============================================
# Air Hockey Base - Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values

# ============================================
# App URL (for Farcaster manifest & sharing)
# ============================================
NEXT_PUBLIC_APP_URL=https://air-hockey-base.vercel.app

# ============================================
# WebSocket Server URL
# ============================================
# For development: ws://localhost:3001/ws
# For production: wss://your-server.onrender.com/ws
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# ============================================
# Game API Server URL
# ============================================
# For development: http://localhost:4000
# For production: https://your-server.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# ============================================
# Base Blockchain Configuration
# ============================================

# Smart contract address (deployed on Base Sepolia)
# Deploy with: cd contracts && npx hardhat run scripts/deploy.ts --network baseSepolia
NEXT_PUBLIC_CONTRACT_ADDRESS=

# WalletConnect Project ID
# Get one at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ============================================
# Farcaster Integration
# ============================================
# HMAC secret for webhook signature verification (optional in dev)
FARCASTER_WEBHOOK_SECRET=

# ============================================
# DEPLOYMENT CHECKLIST
# ============================================
#
# 1. Deploy smart contract to Base Sepolia:
#    cd contracts
#    npx hardhat run scripts/deploy.ts --network baseSepolia
#    Copy the deployed contract address
#
# 2. Deploy WebSocket server to Render/Railway:
#    - Root Directory: server
#    - Build: npm install && npm run build
#    - Start: npm start
#
# 3. Set Vercel environment variables:
#    NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
#    NEXT_PUBLIC_WS_URL=wss://your-server.onrender.com/ws
#    NEXT_PUBLIC_API_URL=https://your-server.onrender.com
#    NEXT_PUBLIC_CONTRACT_ADDRESS=0x...
#    NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=...
#
# 4. Deploy to Vercel: vercel --prod
#
# 5. Generate Farcaster account association:
#    - Use Warpcast Dev Tools Mini App Manifest Tool
#    - Update .well-known/farcaster.json route
#
# 6. Test in Warpcast:
#    - Developer Tools → Mini App Embed Tool → paste URL
